{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      ".git/**",
      ".github/**",
      ".claude/**",
      ".firebaserc",
      ".gitignore",
      "**/node_modules/**",
      "*.md",
      "ChatGPT*.png",
      "**/*.bat",
      "**/*.exe",
      "**/*.cmd",
      "**/*.ps1"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
